{
  "dev_mode": true,
  "environments": [
    {
      "id": "env_greenhouse_a",
      "name": "Smart Greenhouse A",
      "update_interval_sec": 1.0,
      "state_variables": {
        "base_temp": {
          "type": "sine_wave",
          "amplitude": 5.0,
          "period_sec": 60.0,
          "bias": 25.0,
          "noise": 0.1
        },
        "humidity": {
          "type": "random_walk",
          "min_val": 45.0,
          "max_val": 95.0,
          "step": 0.5,
          "initial": 65.0
        }
      }
    }
  ],
  "gateways": [
    {
      "id": "gw_primary",
      "name": "Primary Edge Gateway",
      "buffer_size": 100,
      "aggregation_interval_sec": 3.0,
      "network_reliability": 1.0,
      "connection": {
        "protocol": "http",
        "endpoint": "http://127.0.0.1:8000/api/v1/telemetry",
        "auth": {
          "type": "none"
        }
      }
    }
  ],
  "devices": [
    {
      "id": "sensor_ev_01",
      "name": "Greenhouse Sensor Hub 01",
      "type": "climate_sensor",
      "environment_id": "env_greenhouse_a",
      "gateway_id": "gw_primary",
      "update_interval_sec": 3.0,
      "specs": {
        "firmware": "1.0.0"
      },
      "telemetry_rules": {
        "temperature": "env.base_temp",
        "humidity": "env.humidity",
        "power": "220.0 + random.uniform(-10.0, 10.0)"
      }
    }
  ]
}
